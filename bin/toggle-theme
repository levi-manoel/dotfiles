#!/usr/bin/env bash

set -euo pipefail

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
theme_file="${XDG_CONFIG_HOME}/theme.env"
gtk3_file="${XDG_CONFIG_HOME}/gtk-3.0/settings.ini"
gtk4_file="${XDG_CONFIG_HOME}/gtk-4.0/settings.ini"
ghostty_file="${XDG_CONFIG_HOME}/ghostty/config"

if [[ ! -f "$theme_file" ]]; then
  mkdir -p "$XDG_CONFIG_HOME"
  cat >"$theme_file" <<'EOF'
#!/usr/bin/env sh

THEME="dark"

if [ "$THEME" = "dark" ]; then
  export GTK_THEME="Adwaita:dark"
  export QT_STYLE_OVERRIDE="Adwaita-Dark"
else
  export GTK_THEME="Adwaita"
  export QT_STYLE_OVERRIDE="Adwaita"
fi
EOF
fi

# shellcheck disable=SC1090
source "$theme_file"

current="${THEME:-dark}"
if [[ "${1:-}" == "dark" || "${1:-}" == "light" ]]; then
  next_theme="$1"
else
  if [[ "$current" == "dark" ]]; then
    next_theme="light"
  else
    next_theme="dark"
  fi
fi

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

awk -v next_theme="$next_theme" '
  BEGIN { done=0 }
  /^THEME="/ {
    print "THEME=\"" next_theme "\""
    done=1
    next
  }
  { print }
  END {
    if (!done) print "THEME=\"" next_theme "\""
  }
' "$theme_file" >"$tmp"
install -m 0644 "$tmp" "$theme_file"

apply_gtk_settings() {
  local file="$1"
  local theme_name prefer_dark
  if [[ "$next_theme" == "dark" ]]; then
    theme_name="Adwaita-dark"
    prefer_dark="1"
  else
    theme_name="Adwaita"
    prefer_dark="0"
  fi

  mkdir -p "$(dirname "$file")"
  if [[ ! -f "$file" ]]; then
    printf '[Settings]\n' >"$file"
  fi

  # ensure keys exist/updated (simple, robust replace-or-append)
  grep -q '^gtk-theme-name=' "$file" && \
    sed -i "s/^gtk-theme-name=.*/gtk-theme-name=${theme_name}/" "$file" || \
    printf 'gtk-theme-name=%s\n' "$theme_name" >>"$file"

  grep -q '^gtk-application-prefer-dark-theme=' "$file" && \
    sed -i "s/^gtk-application-prefer-dark-theme=.*/gtk-application-prefer-dark-theme=${prefer_dark}/" "$file" || \
    printf 'gtk-application-prefer-dark-theme=%s\n' "$prefer_dark" >>"$file"
}

apply_gtk_settings "$gtk3_file"
apply_gtk_settings "$gtk4_file"

apply_ghostty_theme() {
  if [[ ! -f "$ghostty_file" ]]; then
    return 0
  fi

  local ghostty_theme
  if [[ "$next_theme" == "dark" ]]; then
    ghostty_theme="Tomorrow Night Bright"
    # Drop light-only overrides so the dark theme controls colors again.
    sed -i '/^[[:space:]]*background[[:space:]]*=/d' "$ghostty_file"
    sed -i '/^[[:space:]]*foreground[[:space:]]*=/d' "$ghostty_file"
  else
    ghostty_theme="Tomorrow"
    # Warm paper background + soft fg: pastels read better than on pure white.
    local warm_bg="#ebe4d9"
    local warm_fg="#3c3744"
    if grep -qE '^[[:space:]]*background[[:space:]]*=' "$ghostty_file"; then
      sed -i "s/^[[:space:]]*background[[:space:]]*=.*/background = ${warm_bg}/" "$ghostty_file"
    else
      printf '\nbackground = %s\n' "$warm_bg" >>"$ghostty_file"
    fi
    if grep -qE '^[[:space:]]*foreground[[:space:]]*=' "$ghostty_file"; then
      sed -i "s/^[[:space:]]*foreground[[:space:]]*=.*/foreground = ${warm_fg}/" "$ghostty_file"
    else
      printf 'foreground = %s\n' "$warm_fg" >>"$ghostty_file"
    fi
  fi

  if grep -qE '^[[:space:]]*theme[[:space:]]*=' "$ghostty_file"; then
    sed -i "s/^[[:space:]]*theme[[:space:]]*=.*/theme = ${ghostty_theme}/" "$ghostty_file"
  else
    printf '\ntheme = %s\n' "$ghostty_theme" >>"$ghostty_file"
  fi

  # Reload Ghostty config (Linux: SIGUSR2).
  if command -v systemctl >/dev/null 2>&1; then
    systemctl reload --user app-com.mitchellh.ghostty.service >/dev/null 2>&1 || true
  fi
  if command -v pkill >/dev/null 2>&1; then
    pkill -USR2 ghostty >/dev/null 2>&1 || true
  fi
}

apply_ghostty_theme

# Set tmux server env so new panes inherit theme.
if command -v tmux >/dev/null 2>&1 && tmux ls >/dev/null 2>&1; then
  if [[ "$next_theme" == "dark" ]]; then
    tmux set-environment -g THEME "dark" || true
    tmux set-environment -g GTK_THEME "Adwaita:dark" || true
    tmux set-environment -g QT_STYLE_OVERRIDE "Adwaita-Dark" || true
  else
    tmux set-environment -g THEME "light" || true
    tmux set-environment -g GTK_THEME "Adwaita" || true
    tmux set-environment -g QT_STYLE_OVERRIDE "Adwaita" || true
  fi
  tmux refresh-client -S >/dev/null 2>&1 || true
fi

if command -v gsettings >/dev/null 2>&1; then
  if [[ "$next_theme" == "dark" ]]; then
    gsettings set org.gnome.desktop.interface color-scheme prefer-dark >/dev/null 2>&1 || true
    gsettings set org.gnome.desktop.interface gtk-theme Adwaita-dark >/dev/null 2>&1 || true
  else
    gsettings set org.gnome.desktop.interface color-scheme default >/dev/null 2>&1 || true
    gsettings set org.gnome.desktop.interface gtk-theme Adwaita >/dev/null 2>&1 || true
  fi
fi

if command -v i3-msg >/dev/null 2>&1; then
  i3-msg reload >/dev/null 2>&1 || true
fi

echo "Theme set to: $next_theme"
echo "For current shell, run: source \"$theme_file\""

