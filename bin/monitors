#!/usr/bin/env bash

if [[ -z "$1" ]]; then
    echo "provide an argument"
    exit 1
fi

if [[ "$1" != "both" && "$1" != "hdmi" && "$1" != "integrated" ]]; then
    echo "arg should be 'both' | 'hdmi' | 'integrated'"
fi

if [[ "$1" == "both" ]]; then
    xrandr --output DP-0 --auto --right-of HDMI-0 -r 60
    xrandr --output HDMI-0 --primary --auto -r 60
fi

if [[ "$1" == "hdmi" ]]; then
    xrandr --output HDMI-0 --primary --auto -r 60
    xrandr --output DP-0 --off
fi

if [[ "$1" == "integrated" ]]; then
    xrandr --output HDMI-0 --off
    xrandr --output DP-0 --primary --auto -r 60
fi

